# =====================================================================
# Good Goddess Almighty — environment variables
# Copy to `.env.local` (local) or configure in Railway dashboard (prod).
# =====================================================================

# Public site URL — used for canonical links, OG images, sitemap.
NEXT_PUBLIC_SITE_URL=https://www.goodgoddessalmighty.com

# Port — Railway injects this automatically; only set locally if needed.
PORT=3000

# -----------------------------------------------------------------
# Contact form email delivery
# -----------------------------------------------------------------
# OPTION A — Resend (recommended): https://resend.com
#   1) Create a Resend account, verify your sending domain.
#   2) Generate an API key with `Sending access` scope.
#   3) Set the variables below.
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
# CONTACT_FROM_EMAIL=hello@goodgoddessalmighty.com
# CONTACT_TO_EMAIL=admin@goodgoddessalmighty.com

# OPTION B — SMTP relay (Postmark, SES, Mailgun, etc.). See README.
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=

# Until either provider is configured, the contact form API writes
# submissions to the server log and returns success. Replace with a
# real handler before launch.
