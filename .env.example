# =====================================================================
# Good Goddess Almighty — environment variables
# Copy to `.env.local` (local) or configure in Railway dashboard (prod).
# =====================================================================

# Public site URL — used for canonical links, OG images, sitemap.
NEXT_PUBLIC_SITE_URL=https://www.goodgoddessalmighty.com

# Port — Railway injects this automatically; only set locally if needed.
PORT=3000

# -----------------------------------------------------------------
# Contact form — Airtable (active)
# -----------------------------------------------------------------
# Submissions are written to an Airtable table. Required columns
# (exact, case-sensitive):
#   Name, Email, Company, Service, Timeline, Budget, Message, ReceivedAt
#
# Create a personal access token at https://airtable.com/create/tokens
# with the `data.records:write` scope, scoped to the target base.
AIRTABLE_TOKEN=patXXXXXXXXXXXXXX.XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
AIRTABLE_BASE_ID=appXXXXXXXXXXXXXX
AIRTABLE_TABLE_NAME=GGA-Contacts
